#include <stdio.h>

#define MAX 10

int n;                      // number of philosophers
int chopstick[MAX];         // semaphore for chopsticks
int room;                   // limits philosophers inside
int hungry[MAX];            // hungry philosophers list

// simulate wait
void wait_sem(int *s) {
    (*s)--;
}

// simulate signal
void signal_sem(int *s) {
    (*s)++;
}

// check if philosopher can eat
int canEat(int i) {
    return (chopstick[i] == 1 && chopstick[(i + 1) % n] == 1);
}

// one philosopher eats at a time
void oneAtATime(int m) {
    printf("Allow one philosopher to eat at any time\n");

    for (int i = 0; i < m; i++) {
        printf("P %d is waiting\n", hungry[i]);
    }

    for (int i = 0; i < m; i++) {
        int p = hungry[i] - 1; // convert to 0-based

        if (canEat(p)) {
            wait_sem(&room);
            wait_sem(&chopstick[p]);
            wait_sem(&chopstick[(p + 1) % n]);

            printf("P %d is granted to eat\n", p + 1);
            printf("P %d has finished eating\n", p + 1);

            signal_sem(&chopstick[p]);
            signal_sem(&chopstick[(p + 1) % n]);
            signal_sem(&room);
        }
    }
}

// two philosophers eat at a time
void twoAtATime(int m) {
    printf("Allow two philosophers to eat at any time\n");

    for (int i = 0; i < m; i++) {
        printf("P %d is waiting\n", hungry[i]);
    }

    for (int i = 0; i < m; i++) {
        int p = hungry[i] - 1;

        if (canEat(p)) {
            wait_sem(&room);
            wait_sem(&chopstick[p]);
            wait_sem(&chopstick[(p + 1) % n]);

            printf("P %d is granted to eat\n", p + 1);
            printf("P %d has finished eating\n", p + 1);

            signal_sem(&chopstick[p]);
            signal_sem(&chopstick[(p + 1) % n]);
            signal_sem(&room);
        }
    }
}

int main() {
    int m, choice;

    printf("Enter the total number of philosophers: ");
    scanf("%d", &n);

    // initialize chopsticks
    for (int i = 0; i < n; i++) {
        chopstick[i] = 1;
    }

    room = n - 1; // avoid deadlock

    printf("How many are hungry: ");
    scanf("%d", &m);

    for (int i = 0; i < m; i++) {
        printf("Enter philosopher %d position (1 to %d): ", i + 1, n);
        scanf("%d", &hungry[i]);
    }

    do {
        printf("\n1. One can eat at a time\n");
        printf("2. Two can eat at a time\n");
        printf("3. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                oneAtATime(m);
                break;
            case 2:
                twoAtATime(m);
                break;
            case 3:
                break;
            default:
                printf("Invalid choice\n");
        }
    } while (choice != 3);

    return 0;
}
